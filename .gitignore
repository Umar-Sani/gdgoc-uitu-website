# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Lockfiles (each developer generates their own) ───────────
frontend/package-lock.json
backend/package-lock.json
frontend/yarn.lock
backend/yarn.lock

# ── Environment variables (NEVER commit these) ───────────────
.env
.env.local
.env.development
.env.production
.env.test
*.env

# ── Next.js build output ─────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/

# ── Backend build output ──────────────────────────────────────
backend/dist/
backend/build/

# ── OS generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── VS Code (optional — some teams commit this, we won't) ─────
.vscode/
*.code-workspace

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────────────────────
.vercel
.turbo
coverage/